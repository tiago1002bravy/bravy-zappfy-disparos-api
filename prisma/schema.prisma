generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  timezone                String   @default("America/Sao_Paulo")
  failureWebhookUrl       String?
  defaultInstanceName     String?
  defaultInstanceTokenEnc String?
  defaultParticipants     String[] @default([])
  // Defaults aplicados em todo grupo criado (front/api/mcp). Override por chamada.
  defaultGroupAdmins      String[] @default([])
  defaultGroupDescription String?
  defaultGroupPictureMediaId String?
  defaultGroupLocked      Boolean  @default(true)
  defaultGroupAnnounce    Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                User[]
  groups               Group[]
  groupLists           GroupList[]
  shortlinks           GroupShortlink[]
  messages             Message[]
  mediaAssets          MediaAsset[]
  schedules            Schedule[]
  groupUpdateSchedules GroupUpdateSchedule[]
  executions           Execution[]
  apiKeys              ApiKey[]
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
}

enum WorkspaceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model WorkspaceRequest {
  id                String                 @id @default(cuid())
  name              String
  slug              String
  requesterName     String
  requesterEmail    String
  passwordHash      String
  reason            String?
  status            WorkspaceRequestStatus @default(PENDING)
  createdAt         DateTime               @default(now())
  reviewedAt        DateTime?
  reviewedByEmail   String?
  rejectionReason   String?
  createdTenantId   String?

  @@index([status, createdAt])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  password  String
  name      String
  role      Role     @default(OPERATOR)
  // Conexão WhatsApp pessoal — quando preenchida, sobrescreve o default do tenant
  instanceName     String?
  instanceTokenEnc String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  hash       String    @unique
  prefix     String
  scopes     String[]
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Group {
  id                String   @id @default(cuid())
  tenantId          String
  instanceName      String
  remoteId          String
  name              String
  description       String?
  pictureUrl        String?
  participantsCount Int?
  syncedAt          DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships    GroupListMembership[]
  shortlinkItems GroupShortlinkItem[]

  // false quando o sync detectou que o grupo nao existe mais na instancia
  // (preserva historico de shortlinks, schedules etc; UI filtra por padrao)
  active Boolean @default(true)

  @@unique([tenantId, instanceName, remoteId])
  @@index([tenantId, name])
  @@index([tenantId, instanceName, active])
}

model GroupShortlink {
  id          String   @id @default(cuid())
  tenantId    String
  slug        String   @unique
  active      Boolean  @default(true)

  // Rotacao
  strategy           ShortlinkStrategy @default(SEQUENTIAL)
  // Limite "duro" do grupo no WhatsApp — quando participantsCount >= hardCap, marca FULL
  hardCap            Int               @default(900)
  // Quantos cliques aguentar ANTES do primeiro recheck via Uazapi
  initialClickBudget Int               @default(800)
  // Fonte primaria de capacidade
  capacitySource     CapacitySource    @default(UAZAPI)

  // Auto-criacao quando todos lotam
  autoCreate         Boolean @default(false)
  autoCreateInstance String?
  autoCreateTemplate String? // padrao: "Grupo {N}"

  // Totais agregados
  clicks        Int       @default(0)
  lastClickedAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      GroupShortlinkItem[]
  clickLog   GroupShortlinkClick[]
  events     GroupShortlinkEvent[]

  @@index([tenantId])
}

model GroupShortlinkItem {
  id          String              @id @default(cuid())
  shortlinkId String
  groupId     String
  order       Int
  status      ShortlinkItemStatus @default(ACTIVE)

  currentInviteUrl String?
  lastRefreshedAt  DateTime?

  // Contadores e ciclo de capacidade
  clicks            Int       @default(0)
  lastClickedAt     DateTime?
  participantsCount Int?
  lastCheckedAt     DateTime?
  // Quando clicks >= nextCheckAtClicks, dispara recheck de capacidade
  nextCheckAtClicks Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shortlink GroupShortlink @relation(fields: [shortlinkId], references: [id], onDelete: Cascade)
  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([shortlinkId, groupId])
  @@index([shortlinkId, status, order])
}

model GroupShortlinkClick {
  id          String   @id @default(cuid())
  shortlinkId String
  itemId      String?
  ip          String?
  userAgent   String?
  country     String?
  countryCode String?
  region      String?
  city        String?
  geoResolved Boolean  @default(false)
  createdAt   DateTime @default(now())

  shortlink GroupShortlink @relation(fields: [shortlinkId], references: [id], onDelete: Cascade)

  @@index([shortlinkId, createdAt])
  @@index([geoResolved, createdAt])
}

model GroupShortlinkEvent {
  id          String   @id @default(cuid())
  shortlinkId String
  itemId      String?
  type        String // recheck | promote_full | auto_create | uazapi_error | no_active_item | invite_refresh
  payload     Json?
  createdAt   DateTime @default(now())

  shortlink GroupShortlink @relation(fields: [shortlinkId], references: [id], onDelete: Cascade)

  @@index([shortlinkId, createdAt])
  @@index([type, createdAt])
}

enum ShortlinkStrategy {
  SEQUENTIAL
  ROUND_ROBIN
  RANDOM
}

enum CapacitySource {
  UAZAPI
  CLICK_COUNT
}

enum ShortlinkItemStatus {
  ACTIVE
  FULL
  INVALID
  DISABLED
}

model GroupList {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships GroupListMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model GroupListMembership {
  id          String @id @default(cuid())
  groupListId String
  groupId     String

  groupList GroupList @relation(fields: [groupListId], references: [id], onDelete: Cascade)
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupListId, groupId])
  @@index([groupId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  tenantId  String
  s3Key     String
  mime      String
  size      Int
  thumbKey  String?
  // Soft-delete: politica do tenant é nunca apagar objetos do MinIO.
  // DELETE /media/:id apenas seta deletedAt e oculta do listing.
  deletedAt DateTime?
  createdAt DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messageMedias MessageMedia[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  text        String?
  mentionAll  Boolean  @default(true)
  // Enquete (opcional). Se pollChoices.length > 0, a mensagem é enviada como enquete.
  pollChoices         String[] @default([])
  pollSelectableCount Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medias    MessageMedia[]
  schedules Schedule[]

  @@index([tenantId])
}

enum MessageMediaKind {
  AUTO       // detecta pelo mime
  IMAGE
  VIDEO
  AUDIO      // áudio normal (MP3/OGG, balão de música)
  PTT        // mensagem de voz (gravada, balão verde)
  DOCUMENT   // anexo genérico
}

model MessageMedia {
  id        String           @id @default(cuid())
  messageId String
  mediaId   String
  order     Int
  kind      MessageMediaKind @default(AUTO)

  message Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  media   MediaAsset @relation(fields: [mediaId], references: [id])

  @@unique([messageId, order])
}

enum ScheduleType {
  ONCE
  DAILY
  WEEKLY
  CUSTOM_CRON
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

model Schedule {
  id               String         @id @default(cuid())
  tenantId         String
  messageId        String
  instanceName     String
  instanceTokenEnc String
  groupRemoteIds   String[]
  groupListIds     String[]       @default([])
  type             ScheduleType
  startAt          DateTime
  endAt            DateTime?
  cron             String?
  timezone         String         @default("America/Sao_Paulo")
  status           ScheduleStatus @default(ACTIVE)
  bullJobId        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message    Message     @relation(fields: [messageId], references: [id])
  executions Execution[]

  @@index([tenantId])
  @@index([status])
}

enum GroupUpdateTarget {
  NAME
  DESCRIPTION
  PICTURE
}

model GroupUpdateSchedule {
  id                String            @id @default(cuid())
  tenantId          String
  instanceName      String
  instanceTokenEnc  String
  groupRemoteId     String
  target            GroupUpdateTarget
  newName           String?
  newDescription    String?
  newPictureMediaId String?
  type              ScheduleType
  startAt           DateTime
  cron              String?
  status            ScheduleStatus    @default(ACTIVE)
  bullJobId         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions Execution[]

  @@index([tenantId])
}

enum ExecStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model Execution {
  id                    String     @id @default(cuid())
  tenantId              String
  scheduleId            String?
  groupUpdateScheduleId String?
  ranAt                 DateTime   @default(now())
  status                ExecStatus
  groupRemoteId         String?
  responsePayload       Json?
  errorMessage          String?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule            Schedule?            @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  groupUpdateSchedule GroupUpdateSchedule? @relation(fields: [groupUpdateScheduleId], references: [id], onDelete: SetNull)

  @@index([tenantId, ranAt])
  @@index([scheduleId])
  @@index([groupUpdateScheduleId])
}
